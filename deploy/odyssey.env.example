# Public Odyssey URL seen by the browser. When hosted under a sub-path, include it here.
# Examples:
# CLIENT_URL=http://localhost:3000
# CLIENT_URL=https://example.mil/odyssey
CLIENT_URL=http://localhost:3000

# AI providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=
AZURE_OPENAI_MODEL=

# GitHub / GitLab
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITLAB_TOKEN=
GITLAB_NPS_HOST=
GITLAB_NPS_TOKEN=

# Google OAuth for Supabase Auth / account linking
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Microsoft 365
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_URL=https://login.microsoftonline.com/common
# Separate callback for Odyssey's direct Microsoft Graph integration flow.
# Supabase Auth sign-in uses CLIENT_URL + /supabase/auth/v1/callback.
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/microsoft/auth/callback
MICROSOFT_TOKEN_ENCRYPT_KEY=
